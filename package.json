{
  "name": "manus-assistant-clone",
  "version": "1.0.0",
  "description": "Full-stack AI assistant clone with frontend, backend, and integrations",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "type-check": "npm run type-check --prefix frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}
